        <mxCell id="g8_LgVaW2ntSlkJ5gvQC-60" parent="1" style="text;whiteSpace=wrap;html=1;fontColor=default;labelBackgroundColor=none;align=center;" value="&lt;div style=&quot;forced-color-adjust: none; font-family: &amp;quot;Architects Daughter&amp;quot;; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;font face=&quot;Times New Roman&quot; style=&quot;forced-color-adjust: none; font-size: 13px;&quot;&gt;&lt;b style=&quot;forced-color-adjust: none;&quot;&gt;Hybrid + Overlap / Missing&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;forced-color-adjust: none; font-family: &amp;quot;Architects Daughter&amp;quot;; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;font face=&quot;Times New Roman&quot; style=&quot;forced-color-adjust: none; font-size: 12px;&quot;&gt;s(r) = α·cos(q&lt;sub style=&quot;forced-color-adjust: none;&quot;&gt;gat&lt;/sub&gt;, r&lt;sub style=&quot;forced-color-adjust: none;&quot;&gt;gat&lt;/sub&gt;) + (1−α)·cos(q&lt;sub style=&quot;forced-color-adjust: none;&quot;&gt;text&lt;/sub&gt;, r&lt;sub style=&quot;forced-color-adjust: none;&quot;&gt;text&lt;/sub&gt;)&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;forced-color-adjust: none; font-family: &amp;quot;Architects Daughter&amp;quot;; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;font face=&quot;Times New Roman&quot; style=&quot;forced-color-adjust: none; font-size: 12px;&quot;&gt;+ γ·overlap(r) − β·missing(r)&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;forced-color-adjust: none; font-family: &amp;quot;Architects Daughter&amp;quot;; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;font face=&quot;Times New Roman&quot; style=&quot;forced-color-adjust: none; font-size: 10px; color: rgb(102, 102, 102);&quot;&gt;5-tier hard-constraint cascade&lt;/font&gt;&lt;/div&gt;" vertex="1">
